<mujoco model="auv_cameras">
  <option gravity="0 0 -9.81" timestep="0.004" density="1000" viscosity="0.001"/>

  <worldbody>
    <light pos="0 0 3"/>
    <geom type="plane" size="10 10 0.1" pos="0 0 -1.5" rgba="0.25 0.35 0.45 1"/>
    <!-- a contrast strip on the seabed so the down camera has something to see -->
    <geom type="box" pos="0 0 -1.49" size="0.08 5 0.005" rgba="1 0.85 0.1 1"/>

    <body name="rov" pos="0 0 0" gravcomp="1">
      <freejoint/>
      <geom type="box" size="0.23 0.15 0.10" density="1000"
            fluidshape="ellipsoid" fluidcoef="0.5 0.25 1.5 1.0 1.0"
            rgba="0.95 0.65 0.15 1"/>
      <geom type="capsule" fromto="0.23 0 0  0.30 0 0" size="0.02" rgba="0.1 0.1 0.1 1"/>

      <site name="t_left"  pos="-0.2  0.12 0" zaxis="1 0 0" size="0.02"/>
      <site name="t_right" pos="-0.2 -0.12 0" zaxis="1 0 0" size="0.02"/>
      <site name="t_vup_f" pos=" 0.15 0 0.06" zaxis="0 0 1" size="0.02"/>
      <site name="t_vup_b" pos="-0.15 0 0.06" zaxis="0 0 1" size="0.02"/>

      <!-- cameras ride with the vehicle -->
      <camera name="down" pos="0 0 -0.10" euler="3.14159 0 0" fovy="70"/>
      <camera name="front" pos="0.24 0 0" euler="1.5708 0 -1.5708" fovy="60"/>
    </body>
  </worldbody>

  <actuator>
    <thruster site="t_left"  name="m_left"  gear="5" ctrlrange="-1 1"/>
    <thruster site="t_right" name="m_right" gear="5" ctrlrange="-1 1"/>
    <thruster site="t_vup_f" name="m_vf"    gear="5" ctrlrange="-1 1"/>
    <thruster site="t_vup_b" name="m_vb"    gear="5" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
