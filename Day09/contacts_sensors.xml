<mujoco model="drop">
  <option gravity="0 0 -9.81" timestep="0.002"/>
  <worldbody>
    <light pos="0 0 3"/>
    <geom name="floor" type="plane" size="3 3 0.1" friction="1 0.005 0.0001"
          rgba="0.8 0.9 0.8 1"/>
    <body name="box" pos="0 0 1">
      <freejoint/>
      <geom type="box" size="0.1 0.1 0.1" density="500" rgba="0.2 0.4 0.9 1"/>
      <site name="imu_site" pos="0 0 0" size="0.02"/>
    </body>
  </worldbody>
  <sensor>
    <gyro name="gyro" site="imu_site"/>
    <accelerometer name="acc" site="imu_site"/>
    <framepos name="pos" objtype="site" objname="imu_site"/>
  </sensor>
</mujoco>
