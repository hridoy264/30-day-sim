<mujoco model="water_drag">
  <!-- density=1000 makes the medium behave like water (buoyancy + drag).
       Try density=1.2 (air) to feel the difference. -->
  <option gravity="0 0 -9.81" timestep="0.002" density="1000" viscosity="0.001"/>

  <worldbody>
    <light pos="0 0 3"/>
    <geom type="plane" size="3 3 0.1" rgba="0.3 0.5 0.7 1"/>

    <body name="blob" pos="0 0 2">
      <freejoint/>
      <!-- density 800 < 1000 -> slightly buoyant; ellipsoid fluid model for tunable drag -->
      <geom type="box" size="0.2 0.15 0.1" density="800"
            fluidshape="ellipsoid" fluidcoef="0.5 0.25 1.5 1.0 1.0"
            rgba="0.9 0.7 0.2 1"/>
    </body>
  </worldbody>
</mujoco>
